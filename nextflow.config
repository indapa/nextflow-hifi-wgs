process {
    errorStrategy = 'retry'
    maxRetries = 2

    // --- High Resource Workhorse Queue (Heavy Lift Group) ---
    withName: 'pbmm2_align|deepvariant_wgs|glnexus_trio_merge' {
        queue  = 'TowerForge-7hxrbYGSOMD6eweMBX4M90'
        cpus   = 16
        memory = { 64.GB * task.attempt }
    }

    // Isolate pbmm2 parameters so they don't corrupt deepvariant/glnexus arguments
    withName: 'pbmm2_align' {
        ext.model_type = 'PACBIO'
        ext.args       = '-m 8G'
    }

    withName: 'deepvariant_wgs' {
        ext.model_type = 'PACBIO'
    }

    withName: 'deeptrio_wgs' {
        queue          = 'TowerForge-7hxrbYGSOMD6eweMBX4M90'
        cpus           = 64
        memory         = { 64.GB * task.attempt } 
        ext.model_type = 'PACBIO'
    }

    // --- Sharded / Massively Parallel Queue ---
    withName: 'deeptrio_wgs_by_chrom' {
        queue            = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus             = 16
        memory           = { 32.GB * task.attempt }
        containerOptions = '-e HOME=/tmp -e PYTHON_RUNFILES_DIRECTORY=/tmp'
        ext.model_type   = 'PACBIO'
        
        // BULLETPROOF ERROR LOGIC (Kept exactly as you designed it)
        errorStrategy    = { 
            if (task.exitStatus in [137, 140, 143, 175, 255] || task.exitStatus == null) {
                return task.attempt <= 3 ? 'retry' : 'ignore'
            } else {
                return 'ignore'
            }
        }
        maxRetries       = 3
        maxErrors        = '-1' 
    }

    withName: 'cpg_methylation_calling' {
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus          = 4
        memory        = { 16.GB * task.attempt }
        maxRetries    = 3
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
    }

    withName: 'hiphase_small_variants' {
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus          = { 4 * task.attempt }
        memory        = { 16.GB * task.attempt }
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
    }

    withName: 'sawfish_discover' {
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus          = { 8 * task.attempt }
        memory        = { 64.GB * task.attempt }
        scratch       = true // Highly recommended for speed on local scratch
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
    }

    withName: 'sawfish_joint_call' {
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus          = { 4 * task.attempt }
        memory        = { 16.GB * task.attempt }
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
    }

    withName: 'mosdepth_run' {
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus          = 4
        memory        = 16.GB
        scratch       = true
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
    }

    withName: 'downsample' {
        queue  = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus   = 4
        memory = { 4.GB * task.attempt }
    }

    withName: 'infer_sex|plot_dist_coverage|bam_stats|slice_trio_bams_by_interval' {
        queue  = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
        cpus   = 2
        memory = { 4.GB * task.attempt }
    }
}

params {
    samplesheet       = null
    hiphase_samplesheet = null
    trio_samplesheet  = null


    reference       = "s3://pacbio-hifi-human-wgs-reference/dataset/hifi-wdl-resources-v2.0.0/GRCh38/human_GRCh38_no_alt_analysis_set.fasta"
    reference_index = "${params.reference}.fai"

    //sawfish2 and trgt related resource files
    expected_XX_bed = "s3://pacbio-datasets/resources/expected_cn/expected_cn.hg38.XX.bed"
    expected_XY_bed = "s3://pacbio-datasets/resources/expected_cn/expected_cn.hg38.XY.bed"
    excluded_bed = "s3://pacbio-datasets/resources/cnv_excluded_regions/annotation_and_common_cnv.hg38.bed.gz"
    intervals_dir = "s3://pacbio-datasets/resources/deepvariant-regions"

    output_dir             = "s3://embedbio-results/hifi-wgs-output"
    downsample_output_dir   = "${params.output_dir}/downsampled-bams"
    aligned_output_dir     = "${params.output_dir}/aligned-bams"
    bam_stats_output_dir   = "${params.output_dir}/bamstats"
    deepvariant_output_dir = "${params.output_dir}/deepvariant"
    hiphase_output_dir     = "${params.output_dir}/hiphase"
    cpg_output_dir         = "${params.output_dir}/cpg"
    mosdepth_output_dir    = "${params.output_dir}/mosdepth"
    sawfish_output_dir     = "${params.output_dir}/sawfish2"

    

    
}

plugins {
    id 'nf-tower@1.28.0'
}


executor {
    
    queueSize       = 30
    submitRateLimit = '30/2min'
}

docker.enabled  = true
wave.enabled    = true
fusion.enabled  = true

profiles {
    local {
        process {
            queue = null
            executor = 'local'

            // 2. Override resource requirements globally for the stub run
            cpus     = 1
            memory   = 2.GB
            disk     = null // Prevents mounting large disk allocations locally

            // 3. Strip process-specific overrides so they don't look for 64GB or 64 CPUs
            withName: '.*' {
                cpus   = 1
                memory = 2.GB
            }

        }
        
        // Define your AWS credentials directly for this profile
        aws {
            accessKey = ''
            secretKey = ''
            // If you are using temporary AWS Academy or SSO credentials, uncomment below:
            // sessionToken = 'your_session_token_here'
        }


        docker {
            enabled = true
        }
        wave.enabled = false
        fusion.enabled = false
    }
}