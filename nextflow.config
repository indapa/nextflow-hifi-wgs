process {
    errorStrategy = 'retry'
    maxRetries = 2

    withName: '^(pbmm2_align|deepvariant_wgs|deeptrio_wgs|glnexus_trio_merge)$' {
        queue = 'TowerForge-7hxrbYGSOMD6eweMBX4M90'
        cpus = 16
        memory = { 64.GB * task.attempt }
        ext.model_type = 'PACBIO'
        ext.args = '-m 8G'
    }



    withName: 'cpg_methylation_calling' {
        cpus          = 4
        memory        = { 16.GB * task.attempt }
        maxRetries    = 3
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'

    }

    withName: 'hiphase_small_variants' {
        cpus          = { 4 * task.attempt }
        memory        = { 16.GB * task.attempt }
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
    }

    withName: 'sawfish_discover' {
        cpus          = { 2 * task.attempt }
        memory        = {64.GB * task.attempt }
        disk         = { 100.GB  }
        scratch       = true
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
    }

    withName: 'sawfish_joint_call' {
        cpus          = 3
        memory        = { 16.GB * task.attempt }
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
    }
    withName: 'mosdepth_run' {
        cpus          = 4
        memory        = 16.GB
        disk          = 100.GB
        scratch       = true
        maxRetries    = 2
        errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
        queue         = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
    }

    withName: 'downsample' {
        cpus = 4
        memory = { 4.GB * task.attempt }
        queue = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
    }

    withName: 'infer_sex|plot_dist_coverage|bam_stats' {
        cpus = 2
        memory = { 4.GB * task.attempt }
        queue = 'TowerForge-65jW9ftzynV2CSKqbQX8BN-work'
    }
}

params {
    samplesheet       = null
    hiphase_samplesheet = null
    trio_samplesheet  = null


    reference       = "s3://pacbio-hifi-human-wgs-reference/dataset/hifi-wdl-resources-v2.0.0/GRCh38/human_GRCh38_no_alt_analysis_set.fasta"
    reference_index = "${params.reference}.fai"

    //sawfish2 and trgt related resource files
    expected_XX_bed = "s3://pacbio-datasets/resources/expected_cn/expected_cn.hg38.XX.bed"
    expected_XY_bed = "s3://pacbio-datasets/resources/expected_cn/expected_cn.hg38.XY.bed"
    excluded_bed = "s3://pacbio-datasets/resources/cnv_excluded_regions/annotation_and_common_cnv.hg38.bed.gz"

    output_dir             = "s3://embedbio-results/hifi-wgs-output"
    downsample_output_dir   = "${params.output_dir}/downsampled-bams"
    aligned_output_dir     = "${params.output_dir}/aligned-bams"
    bam_stats_output_dir   = "${params.output_dir}/bamstats"
    deepvariant_output_dir = "${params.output_dir}/deepvariant"
    hiphase_output_dir     = "${params.output_dir}/hiphase"
    cpg_output_dir         = "${params.output_dir}/cpg"
    mosdepth_output_dir    = "${params.output_dir}/mosdepth"
    sawfish_output_dir     = "${params.output_dir}/sawfish2"

    

    
}

docker.enabled  = true
wave.enabled    = true
fusion.enabled  = true


